{
  "name": "my-turborepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
		"fresh-install": "find . -name \"node_modules\" -type d -prune -exec rm -rf '{}' +; pnpm install",
    "format": "prettier --write \"**/*.{ts,tsx,md,mdx,css,html,js,jsx}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,mdx,css,html,js,jsx}\"",
    "storybook": "turbo run storybook",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "5.9.2",
    "tailwindcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tailwindcss/postcss": "^4",
    "storybook": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@storybook/nextjs-vite": "^10.3.5",
    "eslint-plugin-storybook": "^10.3.5",
    "@chromatic-com/storybook": "^5.1.1",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18"
  }
}
